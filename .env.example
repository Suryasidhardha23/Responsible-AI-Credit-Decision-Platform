# ─────────────────────────────────────────────────────────────
# Responsible AI Credit Decision Platform – Environment Variables
# Copy this file to .env and fill in real values before deployment.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ── Django Core ───────────────────────────────────────────────
SECRET_KEY=django-insecure-replace-this-with-a-50-char-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── PostgreSQL Database ───────────────────────────────────────
# Leave DB_HOST empty to use SQLite for local development.
# Set DB_HOST=db when running with docker-compose.
DB_HOST=
DB_NAME=responsible_ai
DB_USER=postgres
DB_PASSWORD=postgres
DB_PORT=5432

# ── AWS S3 (optional – for production media/model storage) ────
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_REGION_NAME=us-east-1

# ── Email (optional – for password reset flows) ───────────────
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=noreply@example.com
# EMAIL_HOST_PASSWORD=secret
# EMAIL_USE_TLS=True
